<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Song Management</title>
</head>
<body>
    <%- include('../partials/nav') %>
    
    <% if (!song) { %>
        <h1> Add a New Song </h1>
    <% } else { %>
        <br>
        <img src="<%= song.albumCover %>" height="100" width="100" style="object-fit: cover; border-radius: 4px;">
        <h1> Edit <%= song.songName %> </h1>
    <% } %>

    <form id="uploadForm">
        <input type="hidden" id="songId" value="<%= typeof song !== 'undefined' ? song._id : '' %>">

        <label for="fileInput">Select Album Cover:</label>
        <input type="file" id="fileInput" accept="image/*">
        <span class="field-error" id="error-imageData"></span>
        <br><br>
        
        <label for="songName">Song Name:</label>
        <input type="text" id="songName" name="songName" value="<%= typeof song !== 'undefined' ? song.songName : '' %>">
        <span class="field-error" id="error-songName"></span>
        <br><br>
        
        <label for="artistId">Artist:</label>
        <select name="artistId" id="artistId"> 
            <option value="" disabled <%= typeof song === 'undefined' ? 'selected' : '' %>>Select Artist</option>
            <% artists.forEach(artist => { %>
                <option value="<%= artist._id %>"
                    <%= (typeof song !== 'undefined' && song.artistId?._id?.toString() === artist._id.toString()) ? 'selected' : '' %>>
                    <%= artist.artistName %>
                </option>
            <% }) %>
        </select>
        <span class="field-error" id="error-artistId"></span>
        <br><br>   

        <label for="genreId">Genre:</label>
        <select name="genreId" id="genreId">
            <option value="" disabled <%= typeof song === 'undefined' ? 'selected' : '' %>>Select Genre</option>
            <% genres.forEach(genre => { %>
                <option value="<%= genre._id %>" 
                    <%= (typeof song !== 'undefined' && song.genreId?._id?.toString() === genre._id.toString()) ? 'selected' : '' %>>
                    <%= genre.genreName %>
                </option>
            <% }) %>
        </select>
        <span class="field-error" id="error-genreId"></span>
        <br><br>

        <button type="submit">
            <%= typeof song !== 'undefined' ? 'Save Changes' : 'Add Song' %>
        </button>
    </form>

    <%- include('../partials/footer') %>

    <style>
        .field-error {
            color: red;
            font-size: 0.875rem;
            display: block;
            margin-top: 4px;
        }
    </style>

    <script>
        function clearErrors() {
            document.querySelectorAll('.field-error').forEach(el => el.textContent = '');
        }

        function showErrors(errors) {
            if (errors.imageData) document.getElementById('error-imageData').textContent = errors.imageData;
            if (errors.songName)  document.getElementById('error-songName').textContent  = errors.songName;
            if (errors.artistId)  document.getElementById('error-artistId').textContent  = errors.artistId;
            if (errors.genreId)   document.getElementById('error-genreId').textContent   = errors.genreId;
            if (errors.general)   alert("❌ " + errors.general);
        }

        document.getElementById('uploadForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            clearErrors();

            const fileInput    = document.getElementById('fileInput');
            const nameInput    = document.getElementById('songName');
            const artistSelect = document.getElementById('artistId');
            const genreSelect  = document.getElementById('genreId');
            const songId       = document.getElementById('songId').value;

            const file = fileInput.files[0];
            let imageData = null;

            // Convert image to Base64 if a new file is selected
            if (file) {
                imageData = await new Promise((resolve) => {
                    const reader = new FileReader();
                    reader.onload = () => resolve(reader.result);
                    reader.readAsDataURL(file);
                });
            }

            const endpoint = songId ? '/songs/changed' : '/songs/upload';

            const response = await fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    songId,
                    imageData, 
                    songName: nameInput.value,
                    artistId: artistSelect.value, 
                    genreId: genreSelect.value
                })
            });

            const data = await response.json();

            if (response.ok && data.success) {
                window.location.href = '/songs/manage-songs';
            } else {
                showErrors(data.errors || { general: data.message || "An unknown error occurred." });
            }
        });
    </script>
</body>
</html>