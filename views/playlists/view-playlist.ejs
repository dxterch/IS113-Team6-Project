<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create/Edit Playlist</title>
</head>
<body>
    <!-- Mandatory Navigation -->
    <%- include('../partials/nav') %>

    <h1><%= playlist.pname %></h1>
    <%= playlist.caption %>
    <% if (typeof error !== 'undefined' && error) { %>
        <p style="color:red"><%= error %></p>
    <% } %>

    <h3>Songs in this playlist:</h3>

    <% if (playlist.songs && playlist.songs.length>0){ %>
            <table border="1" cellpadding="5" cellspacing="0" width="60%">
    <thead>
        <tr bgcolor="#eeeeee">
            <th></th>
            <th>Songs</th>
            <th>Artist</th>
            <th>Genre</th>
        </tr>
    </thead>
    <tbody>
        <% if (songs.length > 0) { %>
            <% songs.forEach(song => { %>
                <tr>
                    <td width="1">
                        <img src="<%= song.albumCover %>" height="100" width="100" alt="Album Cover">
                    </td>

                    <td>
                        <font size="5"><%= song.songName %></font>
                    </td>

                    <td>
                        <font size="5">
                            <%= song.artistId ? song.artistId.artistName : 'Unknown Artist' %>
                        </font>
                    </td>
                    <td>
                        <font size="5"><%= song.genreId ? song.genreId.genreName : 'No Genre' %></font>
                    </td>

                </tr>
            <% }); %>
        <% } else { %>
            <tr>
                <td colspan="6" align="center">
                    <h3>No songs found matching your search.</h3>
                </td>
            </tr>
        <% } %>
    </tbody>
</table>
<br><br>
            <form action="/playlists/edit-playlist?" method="get">
            <input type="hidden" name="playlistId" value="<%= playlist._id %>">
            <button type="submit">Add/Edit Songs Here</button>
        </form>
    <%} else { %>
        No songs in this playlist yet. 
        <br><br>
        <form action="/playlists/edit-playlist?" method="get">
            <input type="hidden" name="playlistId" value="<%= playlist._id %>">
            <button type="submit">Add/Edit Songs Here</button>
        </form>
    <% } %>
    <br>
    <a href="/auth/home">Back to Home</a>
</body>
</html>