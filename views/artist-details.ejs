<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= artist.artistName %> - Details</title>
</head>
<body>
    <%- include('partials/nav') %>

    <h1>Artist Profile</h1>
    <img 
        src="/images/artists/<%= artist.artistImage %>" 
        alt="<%= artist.artistName %>"
        style="width: 250px; height: 250px; border-radius: 50%; object-fit: cover; display: block;"
    >
    <h2><%= artist.artistName %></h2>

    <p><strong>Country:</strong> <%= artist.artistCountry %></p>
    <p><strong>Gender:</strong> <%= artist.artistGender %></p>
    <p><strong>Genres:</strong> <%= artist.artistGenre.map(g => g.genreName).join(", ") %></p>

    <h3>Artist Biography</h3>
    <p><%= artist.artistBio %></p>
    
    <hr>
    <h3>Songs by <%= artist.artistName %></h3>

    <% if (songs && songs.length > 0) { %>
        <table border="1" cellpadding="10">
            <thead>
                <tr>
                    <th>Cover</th>
                    <th>Song Title</th>
                    <th>Genre</th>
                    <th>Rating</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% songs.forEach(song => { %>
                    <tr>
                        <td>
                            <img src="<%= song.albumCover %>" width="60" height="60" alt="Album Cover">
                        </td>
                        <td>
                            <strong>
                                <%= song.songName %>
                            </strong>
                        </td>
                        <td>
                            <%= song.genreName %>
                        </td>
                        <td>
                            <%= song.avgRating ? song.avgRating.toFixed(1) : 'N/A' %> / 5.0
                        </td>
                        <td>
                            <a href="/reviews-page/song/<%= song._id %>">View Reviews</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <p>This artist hasn't released any songs yet.</p>
    <% } %>

    <!-- Footer -->
    <%- include('partials/footer') %>
</body>
</html>