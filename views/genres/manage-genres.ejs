<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Genres</title>
</head>
<body>
    <%- include('../partials/nav') %>

    <h1>Manage Genres</h1>

    <% if (typeof error !== 'undefined' && error) { %>
        <p style="color: red; font-weight: bold;"><%= error %></p>
    <% } %>
    <% if (typeof msg !== 'undefined' && msg) { %>
        <p style="color: green; font-weight: bold;"><%= msg %></p>
    <% } %>

    <a href="/genres/create">Create New Genre</a>

    <br><br>

    <% if (genres.length === 0) { %>
        <p>No genres available yet.</p>
    <% } else { %>
        <ul>
            <% genres.forEach(genre => { %>
                <li>
                    <strong><%= genre.genreName %></strong>
                    <% if (genre.description) { %>
                        - <%= genre.description %>
                    <% } %>
                    <% if (genre.originYear) { %>
                        | Origin Year: <%= genre.originYear %>
                    <% } %>
                    <% if (genre.regionOrigin) { %>
                        | Region: <%= genre.regionOrigin %>
                    <% } %>

                    <form action="/genres/edit-form" method="post" style="display:inline;">
                        <input type="hidden" name="genreId" value="<%= genre._id %>">
                        <button type="submit">Edit</button>
                    </form>

                    <form action="/genres/delete" method="post" style="display:inline;">
                        <input type="hidden" name="genreId" value="<%= genre._id %>">
                        <button type="submit" onclick="return confirm('Are you sure you want to delete <%= genre.genreName %>? \nClick OK to Continue!')">Delete</button>
                    </form>
                </li>
            <% }) %>
        </ul>
    <% } %>

    <a href="/auth/home">Back to Home</a>

    <%- include('../partials/footer') %>
</body>
</html>