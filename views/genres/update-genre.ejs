<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Genre</title>
</head>
<body>
    <%- include('../partials/nav') %>

    <h1>Update Genre</h1>

    <% if (msg) { %>
        <p style="color: red;"><%= msg %></p>
    <% } %>

    <form action="/genres/update" method="post">
        <input type="hidden" name="genreId" value="<%= genre._id %>">

        <div>
            <label for="genreName">Genre Name:</label>
            <input
                type="text"
                id="genreName"
                name="genreName"
                value="<%= genre.genreName %>"
                required
            >
        </div>

        <br>

        <div>
            <label for="description">Description:</label>
            <textarea id="description" name="description"><%= genre.description %></textarea>
        </div>

        <br>

        <div>
            <label for="originYear">Origin Year:</label>
            <input
                type="number"
                id="originYear"
                name="originYear"
                value="<%= genre.originYear || '' %>"
            >
        </div>

        <br>

        <div>
            <label for="coverImage">Cover Image Filename:</label>
            <input
                type="text"
                id="coverImage"
                name="coverImage"
                value="<%= genre.coverImage || 'default_genre.avif' %>"
            >
        </div>

        <br>

        <div>
            <label for="regionOrigin">Region of Origin:</label>
            <input
                type="text"
                id="regionOrigin"
                name="regionOrigin"
                value="<%= genre.regionOrigin || '' %>"
            >
        </div>

        <br>

        <div>
            <label for="notableStyle">Notable Style:</label>
            <input
                type="text"
                id="notableStyle"
                name="notableStyle"
                value="<%= genre.notableStyle || '' %>"
            >
        </div>

        <br>

        <button type="submit">Update Genre</button>
    </form>

    <br>
    <a href="/genres/manage">Back to Manage Genres</a>

    <%- include('../partials/footer') %>
</body>
</html>