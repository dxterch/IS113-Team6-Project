<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Playlist Management</title>
</head>
<body>
    <h1>This is the Playlist Management Page</h1>
    <h1>
    <%= playlist ? `Edit ${playlistName}` : "New Playlist" %>
</h1>
<form action="/playlist/save" method="post">
    <h3>Playlist Name:</h3>
        <input name="pname" value="<%= pname %>" required>
    <br>

    <h3>Add a caption!</h3>
        <br>
        <textarea name="caption"></textarea>
    <br><br>

    <h3>Songs:</h3>
    <% songs.forEach(song =>{ %>
        <input type="checkbox" name="songs" value="<%= song.id %>"
        <% if (playlist && playlist.songs.includes(song.id.toString())) {%> checked <% } %>>
        <%= song.name %>    -   <%= song.artist %>
        <br>
    <%}) %>
    <br><br>

    <button type="submit">
        <%= playlist ? "Update Playlist" : "Create Playlist" %>
    </button>


</form>
    <a href="/index.html">Back to Home</a>
</body>
</html>