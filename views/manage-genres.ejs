<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Genres</title>
</head>
<body>
    <!-- Mandatory Navigation -->
    <%- include('partials/nav') %>
    
    <h1>Manage Genres</h1>

    <!-- Link to create a new genre -->
    <a href="/genres/create">Create New Genre</a>

    <br><br>

    <!-- If there are no genres, show message -->
    <% if (genres.length === 0) { %>
        <p>No genres available yet.</p>
    <% } else { %>
        <ul>
            <% genres.forEach(genre => { %>
                <li>
                    <strong><%= genre.genreName %></strong>
                    <% if (genre.description) { %>
                        - <%= genre.description %>
                    <% } %>

                    <!-- Edit button sends selected genreId to controller -->
                    <form action="/genres/edit-form" method="post" style="display:inline;">
                        <input type="hidden" name="genreId" value="<%= genre._id %>">
                        <button type="submit">Edit</button>
                    </form>

                    <!-- Delete button sends selected genreId to controller -->
                    <form action="/genres/delete" method="post" style="display:inline;">
                        <input type="hidden" name="genreId" value="<%= genre._id %>">
                        <button type="submit">Delete</button>
                    </form>
                </li>
            <% }) %>
        </ul>
    <% } %>

    <a href="/">Back to Home</a>
    <!-- Footer -->
    <%- include('partials/footer') %>
</body>
</html>