<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Homepage</title>
</head>
<body>
    <!-- Mandatory Navigation -->
    <nav>
        <a href="/auth/home">Homepage</a> | 
        <a href="/songs-page">Search Songs</a> |
        <a href="/artists/manage">Manage Artists</a> |
        <a href="/genres/browse">Browse Genres</a> |
        <% if (isAdmin) { %>
        <a href="/genres/manage">Manage Genres</a> |
    <% } %>
        <a href="/">Back to Index Page</a>
    </nav>

    <hr>

    <!-- Personalized Greeting  -->
    <header>
        <h1>Welcome Back <%= username %>!</h1>
    </header>

    <main>
        <!-- Your Playlists Section -->
        <section>
            <h2>Your Playlists: 
                <a href="/playlists/create""><button type="button">+</button></a>
            </h2>
            <table border="1">
                <thead>
                    <tr>
                        <th>Select</th>
                        <th>Name</th>
                        <th>Date Created</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (playlists.length > 0) { %>
                        <% playlists.forEach(playlist => { %>
                            <tr>
                                <td><input type="checkbox" name="selectedPlaylists" value="<%= playlist.PID %>"></td>
                                <td><a href="/playlists/details/<%= playlist.PID %>"><%= playlist.PName %></a></td>
                                <td><%= playlist.DateCreated %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3">No playlists yet. Get started by adding your favs!</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
            <br>
            <button type="button">Delete</button> 
        </section>

        <br>

        <!-- Your Reviews Section -->
        <section>
            <h2>Your Reviews: 
                <a href="/reviews/post"><button type="button">+</button></a>
            </h2>
            <table border="1">
                <thead>
                    <tr>
                        <th>Select</th>
                        <th>Song</th>
                        <th>Artist</th>
                        <th>Rating</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (reviews.length > 0) { %>
                        <% reviews.forEach(review => { %>
                            <tr>
                                <td><input type="checkbox" name="selectedReviews" value="<%= review.RID %>"></td>
                                <td><%= review.SongName %></td>
                                <td><%= review.ArtistName %></td>
                                <td><%= review.Rating %> / 5</td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4">No reviews yet. Leave ratings for songs on the right!</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
            <br>
            <button type="button">Delete</button> <!-- Button to remove selected reviews -->
        </section>
    </main>
</body>
</html>