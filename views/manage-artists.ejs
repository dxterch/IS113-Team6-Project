<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Artists</title>
</head>

<body>
    <!-- Mandatory Navigation -->
    <%- include('partials/nav') %>

    <h1>Artist Management Page</h1>
    <p>Welcome <%= username %>! Here you can manage the artists for the library.</p>

    <% if (typeof msg !== 'undefined' && msg) { %>
        <p style="color: green; font-weight: bold;"><%= msg %></p>
    <% } %>

    <table border="1">
        <thead>
            <tr>
                <th>Artist Image</th>
                <th>Artist Name</th>
                <th>Artist Gender</th>
                <th>Artist Genre</th>
                <th>Artist Biography</th>
                <th>Manage Artist</th>
            </tr>
        </thead>
        <tbody>
            <% if (artists.length> 0) { %>
                <% artists.forEach(artist=> { %>
                    <tr>
                        <td>
                            <img src="/images/artists/<%= artist.artistImage %>" alt="<%= artist.artistName %>" height="80" width="80">
                        </td>
                        <td>
                            <%= artist.artistName %>
                        </td>
                        <td>
                            <%= artist.artistGender %>
                        </td>
                        <td>
                            <% if (artist.artistGenre && artist.artistGenre.length > 0) { %>
                                <%= artist.artistGenre.map(g => g.genreName).join(", ") %>
                            <% } else { %>
                                No Genre
                            <% } %>
                        </td>
                        <td>
                            <%= artist.artistBio %>
                        </td>
                        <td>
                            <a href="/artists/update?id=<%= artist._id %>">Edit Artist</a> |
                            <form action="/artists/delete" method="post" style="display:inline;">
                                <input type="hidden" name="artistId" value="<%= artist._id %>">
                                <button type="submit" onclick="return confirm('Are you sure you want to delete <%= artist.artistName %>? \nThis action cannot be undone!')">Delete Artist
                            </form>
                        </td>
                    </tr>
                    <% }) %>
            <% } else { %>
                    <tr>
                        <td colspan="5">No Artists Found in the Database.</td>
                    </tr>
            <% } %>
        </tbody>
    </table>
    <br>
    <a href="/artists/create"><button type="button" onclick="return confirm('Are you sure you want to create an Artist?\nClick OK to Continue!')">Create New Artist</button><br><br></a>
</body>
</html>