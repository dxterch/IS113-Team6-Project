<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Update Genre</h1>

    <form action="/genres/update" method="post">
        <!-- Hidden input stores which genre is being updated -->
        <input type="hidden" name="genreId" value="<%= genre._id %>">

        <div>
            <label for="genreName">Genre Name:</label>
            <input type="text" id="genreName" name="genreName" value="<%= genre.genreName %>" required>
        </div>

        <br>

        <div>
            <label for="description">Description:</label>
            <textarea id="description" name="description"><%= genre.description %></textarea>
        </div>

        <br>

        <button type="submit">Update Genre</button>
    </form>

    <br>
    <a href="/genres/manage">Back to Manage Genres</a>
</body>
</html>