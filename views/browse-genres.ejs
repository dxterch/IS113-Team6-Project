<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Genres</title>
</head>
<body>
    <%- include('partials/nav') %>

    <h1>Browse Genres</h1>

    <% if (genres.length === 0) { %>
        <p>No genres found.</p>
    <% } else { %>
        <ul>
            <% genres.forEach(genre => { %>
                <li>
                    <a href="/genres/details?id=<%= genre._id %>">
                        <strong><%= genre.genreName %></strong>
                    </a>

                    <% if (genre.description) { %>
                        - <%= genre.description %>
                    <% } %>

                    <% if (genre.originYear) { %>
                        | Origin Year: <%= genre.originYear %>
                    <% } %>

                    <% if (genre.regionOrigin) { %>
                        | Region: <%= genre.regionOrigin %>
                    <% } %>
                </li>
            <% }) %>
        </ul>
    <% } %>

    <a href="/auth/home">Back to Home</a>

    <%- include('partials/footer') %>
</body>
</html>