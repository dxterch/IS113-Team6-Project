<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Genres</title>
</head>
<body>
    <!-- Mandatory Navigation -->
    <%- include('partials/nav') %>
    
    <h1>Browse Genres</h1>

    <!-- Check whether any genres exist -->
    <% if (genres.length === 0) { %>
        <p>No genres found.</p>
    <% } else { %>
        <ul>
            <% genres.forEach(genre => { %>
                <li>
                    <strong><%= genre.genreName %></strong>
                    <% if (genre.description) { %>
                        - <%= genre.description %>
                    <% } %>
                </li>
            <% }) %>
        </ul>
    <% } %>

    <a href="/">Back to Home</a>
</body>
</html>