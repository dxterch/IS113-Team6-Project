<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Genre</title>
</head>
<body>
    <%- include('partials/nav') %>

    <h1>Create Genre</h1>

    <% if (msg) { %>
        <p style="color: red;"><%= msg %></p>
    <% } %>

    <form action="/genres/create" method="post">
        <div>
            <label for="genreName">Genre Name:</label>
            <input
                type="text"
                id="genreName"
                name="genreName"
                value="<%= genre.genreName %>"
                required
            >
        </div>

        <br>

        <div>
            <label for="description">Description:</label>
            <textarea id="description" name="description"><%= genre.description %></textarea>
        </div>

        <br>

        <div>
            <label for="originYear">Origin Year:</label>
            <input
                type="number"
                id="originYear"
                name="originYear"
                value="<%= genre.originYear %>"
            >
        </div>

        <br>

        <div>
            <label for="coverImage">Cover Image Filename:</label>
            <input
                type="text"
                id="coverImage"
                name="coverImage"
                value="<%= genre.coverImage %>"
                placeholder="e.g. pop.png"
            >
        </div>

        <br>

        <div>
            <label for="regionOrigin">Region of Origin:</label>
            <input
                type="text"
                id="regionOrigin"
                name="regionOrigin"
                value="<%= genre.regionOrigin %>"
                placeholder="e.g. United States"
            >
        </div>

        <br>

        <div>
            <label for="notableStyle">Notable Style:</label>
            <input
                type="text"
                id="notableStyle"
                name="notableStyle"
                value="<%= genre.notableStyle %>"
                placeholder="e.g. Catchy hooks and mainstream appeal"
            >
        </div>

        <br>

        <button type="submit">Create Genre</button>
    </form>

    <br>
    <a href="/genres/manage">Back to Manage Genres</a>

    <%- include('partials/footer') %>
</body>
</html>