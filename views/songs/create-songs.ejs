<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Song Management</title>
</head>
<body>
    <%- include('../partials/nav') %>
    
    <% if (!song) { %>
        <h1> Add a New Song </h1>
    <% } else { %>
        <br>
        <img src="<%= song.albumCover %>" height="100" width="100" style="object-fit: cover; border-radius: 4px;">
        <h1> Edit <%= song.songName %> </h1>
    <% } %>

    <form id="uploadForm">
        <input type="hidden" id="songId" value="<%= typeof song !== 'undefined' ? song._id : '' %>">

        <label for="fileInput">Select Album Cover:</label>
        <input type="file" id="fileInput" accept="image/*" <%= typeof song === 'undefined' ? 'required' : '' %>>
        <br><br>
        
        <label for="songName">Song Name:</label>
        <input type="text" id="songName" name="songName" value="<%= typeof song !== 'undefined' ? song.songName : '' %>" required>
        <br><br>
        
        <label for="artistId">Artist:</label>
        <select name="artistId" id="artistId" required> 
            <option value="" disabled <%= typeof song === 'undefined' ? 'selected' : '' %>>Select Artist</option>
            <% artists.forEach(artist => { %>
                <option value="<%= artist._id %>"
                    <%= (typeof song !== 'undefined' && song.artistId?.toString() === artist._id.toString()) ? 'selected' : '' %>>
                    <%= artist.artistName %>
                </option>
            <% }) %>
        </select>
        <br><br>   

        <label for="genreId">Genre:</label>
        <select name="genreId" id="genreId" required>
            <option value="" disabled <%= typeof song === 'undefined' ? 'selected' : '' %>>Select Genre</option>
            <% genres.forEach(genre => { %>
                <option value="<%= genre._id %>" 
                    <%= (typeof song !== 'undefined' && song.genreId?.toString() === genre._id.toString()) ? 'selected' : '' %>>
                    <%= genre.genreName %>
                </option>
            <% }) %>
        </select>
        <br><br>

        <button type="submit">
            <%= typeof song !== 'undefined' ? 'Save Changes' : 'Add Song' %>
        </button>
    </form>

    <%- include('../partials/footer') %>

    <script>
        document.getElementById('uploadForm').addEventListener('submit', async (e) => {
            e.preventDefault(); 

            const fileInput = document.getElementById('fileInput');
            const nameInput = document.getElementById('songName');
            const artistSelect = document.getElementById('artistId');
            const genreSelect = document.getElementById('genreId');
            const songId = document.getElementById('songId').value;

            const file = fileInput.files[0];
            let imageData = null;

            // Convert image to Base64 if a new file is selected
            if (file) {
                imageData = await new Promise((resolve) => {
                    const reader = new FileReader();
                    reader.onload = () => resolve(reader.result);
                    reader.readAsDataURL(file);
                });
            }

            const endpoint = songId ? '/songs/changed' : '/songs/upload';

            const response = await fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    songId,
                    imageData, 
                    songName: nameInput.value,
                    artistId: artistSelect.value, 
                    genreId: genreSelect.value  // FIXED: Changed from genreName to genreId
                })
            });

            if (response.ok) {
                alert("✅ Success!");
                window.location.href = '/songs/manage-songs';
            } else {
                const errorData = await response.json();
                alert("❌ Failed: " + (errorData.error || errorData.message || "Unknown error"));
            }
        });
    </script>
</body>
</html>