<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Artist</title>
</head>
<body>
    <!-- Mandatory Navigation -->
    <!-- Mandatory Navigation -->
    <%- include('partials/nav') %>

    <h1>Update Artist: <%= artist.artistName %></h1>

    <form action="/artists/update" method="post">
        <input type="hidden" name="artistId" value="<%= artist._id %>">

        <label>Artist Genre:</label><br>
        <% genres.forEach(genre => { %>
            <%
                let isChecked = "";
                <!-- Loop through Artist's Genres -->
                if (artist.artistGenre && Array.isArray(artist.artistGenre)) {
                    for (let currentGenreId of artist.artistGenre) {
                        <!-- Compare IDs as Strings -->
                        if (currentGenreId.toString() === genre._id.toString()) {
                            isChecked = "checked";
                            break;
                        }
                    }
                }
            %>
            <input type="checkbox" name="artistGenre" value="<%= genre._id %>" <%= isChecked %>
            <label><%= genre.genreName %></label>
        <% }) %><br><br>

        <label>Artist Biography</label><br>
        <textarea name="artistBio" rows="4" cols="30"><%= artist.artistBio %></textarea><br><br>

        <label>Popularity Rating:</label><br>
        <input type="number" name="artistPopularity" value="<%= artist.artistPopularity %>" min="1" max="100"><br><br>
        
        <button type="submit">Update Artist</button> | 
        <a href="/artists/manage">Cancel</a>
    </form>
</body>
</html>