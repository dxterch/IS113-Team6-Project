<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= artist.artistName %> - Details</title>
</head>
<body>
    <%- include('../partials/nav') %>

    <h1>Artist Profile</h1>

    <img 
        src="/images/artists/<%= artist.artistImage %>" 
        alt="<%= artist.artistName %>"
        style="width: 250px; height: 250px; border-radius: 50%; object-fit: cover; display: block;"
    >

    <div style="display: flex; align-items: center; gap: 15px; margin-top: 15px;">
        <h2 style="margin: 0;"><%= artist.artistName %></h2> 
        
        <p style="margin: 0; border-left: 2px solid #ccc; padding-left: 15px;">
            <strong>Followers:</strong> <%= (artist.artistFollowers || []).length %>
        </p>

        <form action="/artists/follow/<%= artist._id %>" method="POST" style="margin: 0;">
            <input type="hidden" name="artistId" value="<%= artist._id %>">

            <% if ((artist.artistFollowers || []).includes(String(session.userId))) { %>
                <button type="submit" style="background-color: red; color: white; padding: 5px 12px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
                    Unfollow
                </button>
            <% } else { %>
                <button type="submit" style="background-color: green; color: white; padding: 5px 12px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
                    Follow
                </button>
            <% } %>
                | View All Artists You Follow <a href="/artists/following"> Here!</a>
        </form>
        
    </div>
    

    <p><strong>Country:</strong> <%= artist.artistCountry %></p>
    <p><strong>Gender:</strong> <%= artist.artistGender %></p>
    <p><strong>Genres:</strong> <%= artist.artistGenre.map(g => g.genreName).join(", ") %></p>

    <h3>Artist Biography</h3>
    <p><%= artist.artistBio %></p>
    
    <hr>
    <h3>Songs by <%= artist.artistName %></h3>

    <% if (songs && songs.length > 0) { %>
        <table border="1" cellpadding="10">
            <thead>
                <tr>
                    <th>Cover</th>
                    <th>Song Title</th>
                    <th>Genre</th>
                    <th>Rating</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% songs.forEach(song => { %>
                    <tr>
                        <td>
                            <img src="<%= song.albumCover %>" width="60" height="60" alt="Album Cover">
                        </td>
                        <td>
                            <strong>
                                <%= song.songName %>
                            </strong>
                        </td>
                        <td>
                            <%= song.genreId.genreName %>
                        </td>
                        <td>
                            <%= song.avgRating ? song.avgRating.toFixed(1) : 'N/A' %> / 5.0
                        </td>
                        <td>
                            <a href="/reviews-page/song/<%= song._id %>">View Reviews</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <p>This artist hasn't released any songs yet.</p>
    <% } %>

    <!-- Footer -->
    <%- include('../partials/footer') %>
</body>
</html>