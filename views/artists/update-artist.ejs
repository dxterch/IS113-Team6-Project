<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Artist</title>
</head>
<body>
    <!-- Mandatory Navigation -->
    <%- include('../partials/nav') %>

    <h1>Update Artist: <%= artist.artistName %></h1>

    <!-- Missing Fields Error Message -->
    <% if (typeof missingFields !== 'undefined' && missingFields.length > 0) { %>
        <div style="color: red; border: 1px solid red; padding: 10px; margin-bottom: 20px;">
            <strong>ERROR:</strong> The following fields are required:
            <ul>
                <% missingFields.forEach(field => { %>
                    <li>
                        <%= field %>
                    </li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <!-- General Error Message -->
    <% if (typeof msg !== 'undefined' && msg) { %>
        <p style="color: red; font-weight: bold;"><%= msg %></p>
    <% } %>

    <form action="/artists/update" method="post">
        <input type="hidden" name="artistId" value="<%= artist._id %>">

        <% 
            let displayImg = "/images/artists/" + artist.artistImage;
            if (typeof artist !== 'undefined' && artist.artistImageBase64) {
                displayImg = artist.artistImageBase64;
            }
        %>

        <img id="imagePreview"
            src="<%= displayImg %>" 
            alt="<%= artist.artistName %>"
            style="width: 250px; height: 250px; border-radius: 50%; object-fit: cover; display: block; margin-bottom: 10px;"
        ><br>

        <input type="hidden" name="existingArtistImage" value="<%= artist.artistImage %>">

        <label>Upload New Artist Image:</label> 
        <input type="file" id="imageInput" accept="image/*">
        <input type="hidden" name="artistImageBase64" id="artistImageBase64"><br>
        <small>Note: Leave blank to keep current image.</small>

        <script>
            // Convert selected file to Base64 string automatically
            document.getElementById('imageInput').addEventListener('change', function(event) {
                const file = event.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        document.getElementById('artistImageBase64').value = e.target.result;

                        // Update the existing preview dynamically
                        document.getElementById('imagePreview').src = e.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            });
        </script><br><br>

        <label>Artist Name:</label><br>
        <input type="text" name="artistName" value="<%= artist.artistName %>"><br><br>

        <label>Artist Gender: </label><br>
        <% ['Male', 'Female', 'Other'].forEach(gender => { %>
            <input type="radio" id="<%= gender %>" name="artistGender" value="<%= gender %>"
                <%= (typeof artist !== 'undefined' && artist.artistGender === gender) ? 'checked' : '' %>>
            <label for="<%= gender %>"><%= gender %></label><br>
        <% }) %><br>

        <label>Artist Genre:</label><br>
        <% genres.forEach(genre => { %>
            <% 
                let isChecked = "";
                // Ensure the artistGenre property exists and is an array [Source 51]
                if (artist.artistGenre && Array.isArray(artist.artistGenre)) {
                    // Loop through the selected genre IDs
                    for (let currentGenreId of artist.artistGenre) {
                        // Check that currentGenreId is NOT null/undefined before calling .toString()
                        if (currentGenreId && currentGenreId.toString() === genre._id.toString()) {
                            isChecked = "checked";
                            break; 
                        }
                    }
                }
            %>
            <input type="checkbox" id="<%= genre._id %>" name="artistGenre" value="<%= genre._id %>" <%= isChecked %>>
            <label for="<%= genre._id %>"><%= genre.genreName %></label><br>
        <% }) %><br>

        <label>Artist Biography</label><br>
        <textarea name="artistBio" rows="5" cols="60"><%= artist.artistBio %></textarea><br><br>

        <label>Artist Country</label><br>
        <select name="artistCountry">
            <% countries.forEach(country => { %>
                <option value="<%= country %>" <%= artist.artistCountry === country ? 'selected' : '' %>>
                    <%= country %>
                </option>
            <% }) %>
        </select><br><br>

        <button type="submit" onclick="return confirm('Are you sure you want to update <%= artist.artistName %>? \nClick OK to Continue!')">Update Artist</button> | 
        <a href="/artists/manage">Cancel</a>
    </form>
    <!-- Footer -->
    <%- include('../partials/footer') %>
</body>
</html>