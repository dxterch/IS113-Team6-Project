<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Artists</title>
</head>

<body>
    <!-- Mandatory Navigation -->
    <%- include('../partials/nav') %>

    <h1>Artist Management Page</h1>
    <p>Welcome <%= username %>! Here you can manage the artists for the library.</p>

    <a href="/artists/create"><button type="button">Create New Artist</button><br><br></a>
    <!-- Success Message: Green -->
    <% if (typeof msg !== 'undefined' && msg) { %>
        <div style="margin-top: 20px; padding: 10px; background-color: lightgreen; color: green; border: 1px solid black;">
            <strong>SUCCESS: <%= msg %></strong>
        </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
        <div style="margin-top: 20px; padding: 10px; background-color: lightpink; color: red; border: 1px solid black;">
            <strong>ERROR: <%= error %></strong>
        </div>
    <% } %><br>

    <form action="/artists/manage" method="post">
        <input type="text" name="artistSearch" placeholder="🔎 Search for an artist..." value="<%= typeof search !== 'undefined' ? search : '' %>">
        <button type="submit">SEARCH</button>

        <% if (typeof search !== 'undefined' && search) { %>
            | <a href="/artists/manage">Clear Search</a>
        <% } %>
    </form><br>

    <table border="1">
        <thead>
            <tr>
                <th>Artist Image</th>
                <th>Artist Name</th>
                <th>Artist Gender</th>
                <th>Artist Main Genre(s)</th>
                <th>Artist Biography</th>
                <th>Manage Artist</th>
            </tr>
        </thead>
        <tbody>
            <% if (artists.length> 0) { %>
                <% artists.forEach(artist=> { %>
                    <tr>
                        <td>
                            <img src="/images/artists/<%= artist.artistImage %>" alt="<%= artist.artistName %>" height="80" width="80">
                        </td>
                        <td>
                            <%= artist.artistName %>
                        </td>
                        <td>
                            <%= artist.artistGender %>
                        </td>
                        <td>
                            <% if (artist.artistGenre && artist.artistGenre.length > 0) { %>
                                <%= artist.artistGenre.filter(g => g).map(g => g.genreName).join(", ") %>
                            <% } else { %>
                                No Genre
                            <% } %>
                        </td>
                        <td>
                            <%= artist.artistBio %>
                        </td>
                        <td>
                            <!-- View Artist -->
                            <button type="button" onclick="window.location.href='/artists/details?id=<%= artist._id %>'">
                                View Artist
                            </button> |

                            <!-- Edit Artist -->
                            <button type="button" onclick="window.location.href='/artists/update?id=<%= artist._id %>'">
                                Edit Artist
                            </button> |
                            <!-- Delete Artist -->
                            <form action="/artists/delete" method="post" style="display:inline;">
                                <input type="hidden" name="artistId" value="<%= artist._id %>">
                                <button type="submit" onclick="return confirm('Are you sure you want to delete <%= artist.artistName %>? \nThis action cannot be undone!')">Delete Artist</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
            <% } else { %>
                    <tr>
                        <td colspan="5">No Artists Found in the Database.</td>
                    </tr>
            <% } %>
        </tbody>
    </table>
    <br>
    <!-- Footer -->
    <%- include('../partials/footer') %>
</body>
</html>