<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Artist</title>
</head>
<body>
    <!-- Mandatory Navigation -->
    <%- include('partials/nav') %>
    
    <h1>Add a New Artist</h1>
    
    <!-- Missing Fields Error Message -->
    <% if (typeof missingFields !== 'undefined' && missingFields.length > 0) { %>
        <div style="color: red; border: 1px solid red; padding: 10px; margin-bottom: 20px;">
            <strong>ERROR:</strong> The following fields are required:
            <ul>
                <% missingFields.forEach(field => { %>
                    <li>
                        <%= field %>
                    </li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <!-- General Error Message -->
    <% if (typeof msg !== 'undefined' && msg) { %>
        <p style="color: red; font-weight: bold;"><%= msg %></p>
    <% } %>

    <form action="/artists/create" method="post">
        <label>Artist Image Filename (Optional):</label><br>
        <input type="text" name="artistImage" value="<%= typeof artist !== 'undefined' ? artist.artistImage : '' %>" placeholder="e.g. Eminem.jpg">
        | <small>Note: Upload the Image File to Project first.</small><br><br>

        <label>Artist Name: </label><br>
        <input type="text" name="artistName" value="<%= typeof artist !== 'undefined' ? artist.artistName : '' %>"><br><br>

        <label>Artist Gender: </label><br>
        <% ['Male', 'Female', 'Other'].forEach(gender => { %>
            <input type="radio" id="<%= gender %>" name="artistGender" value="<%= gender %>"
                <%= (typeof artist !== 'undefined' && artist.artistGender === gender) ? 'checked' : '' %>>
            <label for="<%= gender %>"><%= gender %></label><br>
        <% }) %><br>

        <label>Select Artist Genres: </label> <br>
        <% genres.forEach(genre => { %>
            <input type="checkbox" id="<%= genre._id %>" name="artistGenre" value="<%= genre._id %>"
                <%= (typeof artist !== 'undefined' && artist.artistGenre && artist.artistGenre.includes(genre._id.toString())) ? 'checked' : '' %>>
            <label for="<%= genre._id %>"><%= genre.genreName %></label><br>
        <% }) %><br>

        <label>Artist Biography: </label><br>
        <textarea name="artistBio" rows="4" cols="30"><%= typeof artist !== 'undefined' ? artist.artistBio : '' %></textarea><br><br>

        <label>Artist Country: </label> <br>
        <select name="artistCountry">
            <option value="">-- Select a Country --</option>
            <% countries.forEach(country => { %>
                <option value="<%= country %>"
                    <%= (typeof artist !== 'undefined' && artist.artistCountry === country) ? 'selected' : '' %>>
                    <%= country %>
                </option>
            <% }) %>
        </select><br><br>

        <button type="submit">Add Artist</button> | 
        <a href="/artists/manage">Cancel</a>
    </form>
    <!-- Footer -->
    <%- include('partials/footer') %>
</body>
</html>